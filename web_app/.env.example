# 인비즈 경영관리 — 환경변수 예시 (.env 로 복사해 값을 채우세요)
# ⚠️ 실제 .env 는 git에 커밋하지 않습니다. 서버에는 데이터 패치로 전달합니다.

# 공통 로그인 비밀번호 (강력하게 설정)
INVIZ_PASSWORD=change-this-strong-password
# 세션 서명 키 (64 hex 권장: python -c "import secrets;print(secrets.token_hex(32))")
INVIZ_SECRET=change-this-to-a-random-64-hex-string

# 포트 / HTTPS (로컬 실행용 — Docker 배포 시에는 Caddy가 HTTPS 처리)
INVIZ_PORT=8000
INVIZ_HTTPS=0

# Docker 배포용
# 공개 배포 보안 모드(서버 폴더 탐색 비활성). 배포 시 1
INVIZ_PUBLIC=1
# DB 경로(컨테이너 볼륨). docker-compose 에서 자동 주입됨
# INVIZ_DB_PATH=/app/data/app.db
# Caddy 자동 HTTPS 도메인 (없으면 :80)
SITE_ADDRESS=inviz.example.com
# Ollama(로컬 LLM) 접속 — docker-compose의 ollama 서비스 사용 시
OLLAMA_HOST=http://ollama:11434

# 참고: API 키·메일/카카오/텔레그램 비밀번호·국세청 키 등은 .env 가 아니라
#       앱 설정(설정 화면 → DB app_setting)에 저장됩니다. (app.db 안에 포함 → 데이터 패치로 전달)
