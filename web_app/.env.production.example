# === 인비즈 경영관리 배포 환경변수 ===
# 이 파일을 .env 로 복사해서 값을 채우세요. (.env 는 절대 git/공개 금지!)

# 1) 공유 로그인 비밀번호 — 반드시 강력하게 변경
INVIZ_PASSWORD=CHANGE-ME-strong-passphrase

# 2) 세션 서명 키 (아래 명령으로 생성해 붙여넣기)
#    python -c "import secrets;print(secrets.token_hex(32))"
INVIZ_SECRET=PUT-64-HEX-CHARS-HERE

# 3) 접속 도메인 — DNS A레코드가 이 서버 공인 IP를 가리켜야 자동 HTTPS가 발급됩니다.
#    도메인이 아직 없으면 테스트용으로  :80  (http) 로 둘 수 있습니다.
SITE_ADDRESS=inviz.example.com
